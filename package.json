{
  "name": "sgf-app",
  "version": "0.6.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "exercises:seed": "node --env-file=.env.local scripts/seed-exercise-library.mjs",
    "exercises:enrich-youtube": "node --env-file=.env.local scripts/enrich-youtube-videos-headless.mjs",
    "exercises:enrich-ai": "node --env-file=.env.local scripts/enrich-exercises-openai.mjs",
    "exercises:backfill-muscles": "node --env-file=.env.local scripts/backfill-muscle-groups.mjs",
    "workouts:backfill-day-tags": "node --env-file=.env.local scripts/backfill-workout-day-tags.mjs",
    "workouts:backfill-day-tags:apply": "node --env-file=.env.local scripts/backfill-workout-day-tags.mjs --apply",
    "workouts:report-day-tags": "node --env-file=.env.local scripts/report-workout-day-tags.mjs",
    "workouts:report-day-tags:json": "node --env-file=.env.local scripts/report-workout-day-tags.mjs --json",
    "workouts:report-day-tags:untagged": "node --env-file=.env.local scripts/report-workout-day-tags.mjs --only-untagged",
    "workouts:report-day-tags:untagged:json": "node --env-file=.env.local scripts/report-workout-day-tags.mjs --only-untagged --json",
    "templates:seed:nasm": "node --env-file=.env.local scripts/seed-nasm-opt-templates.mjs",
