  "dependencies": {
    "@stripe/stripe-js": "^9.1.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
